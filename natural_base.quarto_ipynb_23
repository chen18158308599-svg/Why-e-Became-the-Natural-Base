    "#| echo: false\n",
    "\n",
    "import numpy as np\n",
    "import plotly.graph_objects as go\n",
    "\n",
    "e = np.e\n",
    "\n",
    "# x-range\n",
    "x = np.linspace(-2, 2, 400)\n",
    "\n",
    "# slider values\n",
    "bases = np.round(np.arange(1.2, 5.01, 0.02), 2)\n",
    "\n",
    "fig = go.Figure()\n",
    "\n",
    "# initial base\n",
    "a0 = e\n",
    "y0 = a0**x\n",
    "slope0 = np.log(a0)\n",
    "tangent0 = 1 + slope0 * x\n",
    "\n",
    "# exponential curve\n",
    "fig.add_trace(\n",
    "    go.Scatter(\n",
    "        x=x,\n",
    "        y=y0,\n",
    "        mode=\"lines\",\n",
    "        name=\"y = aˣ\",\n",
    "        line=dict(width=4)\n",
    "    )\n",
    ")\n",
    "\n",
    "# tangent line\n",
    "fig.add_trace(\n",
    "    go.Scatter(\n",
    "        x=x,\n",
    "        y=tangent0,\n",
    "        mode=\"lines\",\n",
    "        name=\"Tangent at x=0\",\n",
    "        line=dict(dash=\"dash\", width=3)\n",
    "    )\n",
    ")\n",
    "\n",
    "# point (0,1)\n",
    "fig.add_trace(\n",
    "    go.Scatter(\n",
    "        x=[0],\n",
    "        y=[1],\n",
    "        mode=\"markers\",\n",
    "        name=\"(0,1)\",\n",
    "        marker=dict(size=10)\n",
    "    )\n",
    ")\n",
    "\n",
    "steps = []\n",
    "\n",
    "for a in bases:\n",
    "\n",
    "    y = (a**x).tolist()\n",
    "    slope = np.log(a)\n",
    "    tangent = (1 + slope*x).tolist()\n",
    "\n",
    "    if abs(a - e) < 0.03:\n",
    "        message = (\n",
    "            \"<b>🎉 You found it!</b><br>\"\n",
    "            f\"a ≈ {e:.5f}<br>\"\n",
    "            \"This number is e.\"\n",
    "        )\n",
    "    else:\n",
    "        message = (\n",
    "            f\"<b>Base a = {a:.2f}</b><br>\"\n",
    "            f\"Slope at x=0 = ln(a) = {slope:.4f}\"\n",
    "        )\n",
    "\n",
    "    step = dict(\n",
    "        method=\"update\",\n",
    "        args=[\n",
    "            {\n",
    "                \"y\": [y, tangent, [1]]\n",
    "            },\n",
    "            {\n",
    "                \"title\": (\n",
    "                    \"Which base makes the tangent slope exactly 1?\"\n",
    "                    f\"<br><sup>{message}</sup>\"\n",
    "                )\n",
    "            },\n",
    "            [0, 1, 2]\n",
    "        ],\n",
    "        label=f\"{a:.2f}\"\n",
    "    )\n",
    "\n",
    "    steps.append(step)\n",
    "\n",
    "fig.update_layout(\n",
    "    title=(\n",
    "        \"Which base makes the tangent slope exactly 1?\"\n",
    "        f\"<br><sup>Base a = {a0:.3f}, ln(a) = {slope0:.4f}</sup>\"\n",
    "    ),\n",
    "    width=900,\n",
    "    height=600,\n",
    "    xaxis_title=\"x\",\n",
    "    yaxis_title=\"y\",\n",
    "    yaxis_range=[-1, 8],\n",
    "    sliders=[\n",
    "        dict(\n",
    "            active=int(np.argmin(np.abs(bases - e))),\n",
    "            currentvalue={\n",
    "                \"prefix\": \"Base a = \"\n",
    "            },\n",
    "            pad={\"t\": 40},\n",
    "            steps=steps\n",
    "        )\n",
    "    ],\n",
    "    annotations=[\n",
    "        dict(\n",
    "            x=0.02,\n",
    "            y=0.95,\n",
    "            xref=\"paper\",\n",
    "            yref=\"paper\",\n",
    "            align=\"left\",\n",
    "            showarrow=False,\n",
    "            text=(\n",
    "                \"d/dx aˣ = (ln a)·aˣ\"\n",
    "                \"<br>\"\n",
    "                \"y<sub>tangent</sub> = 1 + ln(a)·x\"\n",
    "            )\n",
    "        )\n",
    "    ]\n",
    ")\n",
    "\n",
    "fig"
